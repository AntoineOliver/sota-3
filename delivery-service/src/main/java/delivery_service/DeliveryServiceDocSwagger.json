{
  "openapi": "3.0.1",
  "info": {
    "title": "Delivery Service API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local Delivery Service"
    }
  ],

  "paths": {

    "/api/deliveries": {
      "post": {
        "tags": ["Delivery"],
        "summary": "Create a delivery",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeliveryRequestDTO" }
            }
          }
        },
        "responses": {
          "200": { "description": "Delivery created, returns deliveryId", "content": { "application/json": { "schema": { "type": "string" } } } },
          "400": { "description": "Invalid request" },
          "500": { "description": "Server error" }
        }
      }
    },

    "/api/deliveries/{deliveryId}/start": {
      "post": {
        "tags": ["Delivery"],
        "summary": "Start a delivery",
        "parameters": [
          { "name": "deliveryId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Delivery started" },
          "404": { "description": "Delivery not found" }
        }
      }
    },

    "/api/deliveries/{deliveryId}/status": {
      "get": {
        "tags": ["Delivery"],
        "summary": "Get delivery status",
        "parameters": [
          { "name": "deliveryId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Delivery status",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeliveryStatusDTO" } } }
          },
          "404": { "description": "Delivery not found" }
        }
      }
    },

    "/api/deliveries/{deliveryId}/remaining-time": {
      "get": {
        "tags": ["Delivery"],
        "summary": "Get remaining time",
        "parameters": [
          { "name": "deliveryId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Remaining time",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RemainingDurationDTO" } } }
          },
          "404": { "description": "Delivery not found" }
        }
      }
    }
  },

  "components": {
    "schemas": {

      "DeliveryRequestDTO": {
        "type": "object",
        "properties": {
          "sender": { "type": "string" },
          "receiver": { "type": "string" },
          "pickupLat": { "type": "number", "format": "double" },
          "pickupLng": { "type": "number", "format": "double" },
          "dropoffLat": { "type": "number", "format": "double" },
          "dropoffLng": { "type": "number", "format": "double" }
        }
      },

      "DeliveryStatusDTO": {
        "type": "object",
        "properties": {
          "deliveryId": { "type": "string" },
          "status": { "type": "string" }
        }
      },

      "RemainingDurationDTO": {
        "type": "object",
        "properties": {
          "deliveryId": { "type": "string" },
          "remainingMinutes": { "type": "integer" }
        }
      }
    }
  }
}
