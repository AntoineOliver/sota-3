{
  "openapi": "3.0.1",
  "info": {
    "title": "Drone Fleet Service API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8082",
      "description": "Local Drone Fleet Service"
    }
  ],

  "paths": {
    "/drones/assign": {
      "post": {
        "tags": ["Drone"],
        "summary": "Assign a drone to delivery",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DroneAssignmentRequestDTO" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Drone assigned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DroneAssignmentResponseDTO" }
              }
            }
          },
          "400": { "description": "Assignment failed" }
        }
      }
    }
  },

  "components": {
    "schemas": {

      "DroneAssignmentRequestDTO": {
        "type": "object",
        "properties": {
          "deliveryId": { "type": "string" },
          "pickupLat": { "type": "number", "format": "double" },
          "pickupLng": { "type": "number", "format": "double" },
          "dropoffLat": { "type": "number", "format": "double" },
          "dropoffLng": { "type": "number", "format": "double" }
        }
      },

      "DroneAssignmentResponseDTO": {
        "type": "object",
        "properties": {
          "droneId": { "type": "string", "nullable": true },
          "error": { "type": "string", "nullable": true }
        }
      }
    }
  }
}
